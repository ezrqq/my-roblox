--[[ MAIN ESP UPDATE LOOP ]]
runningTasks.espUpdate = task.spawn(function()
    while task.wait(CONFIG.Performance.ESPUpdateInterval) do
        safeCall(function()
            slasherSortType = "N/A"
            slasherChainsawCount = "N/A"
            local slasherFoundForUI = false
            
            if not (state.showSlasher or state.showSurvivors or state.showFriends or state.showEscapes or state.showBatterys or state.showBandages or state.showCoins or state.showFilms or state.showMedkits or state.showChainsaws) then
                return
            end
            
            local char = LocalPlayer.Character
            if not char then return end
            
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            
            local hrpPosition = hrp.Position
            itemCounts = {coins = 0, films = 0, medkits = 0, batterys = 0, bandages = 0}
            
            for obj, info in pairs(espHandles) do
                if info and info.adornee and info.gui and info.gui.Parent then
                    local adornee = info.adornee
                    if adornee and adornee.Parent then
                        local distance = (adornee.Position - hrpPosition).Magnitude
                        
                        if distance > CONFIG.Performance.MaxESPDistance and info.type ~= "Slasher" then
                            continue
                        end
                        
                        if info.type == "Slasher" then
                            local currentSlasherColor = CONFIG.PlayerColors.Slasher
                            local hasChainsaw = false
                            local stats = findStats(obj)
                            
                            if stats then
                                local chainsawCountVal = stats:FindFirstChild("Chainsaw")
                                if chainsawCountVal and chainsawCountVal:IsA("NumberValue") and chainsawCountVal.Value > 0 then
                                    hasChainsaw = true
                                    currentSlasherColor = CONFIG.PlayerColors.SlasherWithChainsaw
                                else
                                    hasChainsaw = false
                                    currentSlasherColor = CONFIG.PlayerColors.Slasher
                                end
                                
                                if not slasherFoundForUI then
                                    slasherFoundForUI = true
                                    local sortType = stats:FindFirstChild("SortType")
                                    if sortType and sortType:IsA("StringValue") then
                                        slasherSortType = sortType.Value
                                    else
                                        slasherSortType = "Unknown"
                                    end
                                    
                                    if hasChainsaw then
                                        slasherChainsawCount = tostring(chainsawCountVal.Value)
                                    else
                                        slasherChainsawCount = "N/A"
                                    end
                                end
                                
                            else 
                                if not slasherFoundForUI then
                                    slasherFoundForUI = true
                                    slasherSortType = "Unknown"
                                    slasherChainsawCount = "N/A"
                                end
                            end
                            
                            if info.box and info.box.Parent then
                                info.box.Color3 = currentSlasherColor
                            end
                            
                            local espText = info.gui:FindFirstChild("ESP_Text")
                            if espText and info.playerName then
                                local distText = (distance > 2000) and "" or string.format(" (%.0fm)", distance)
                                espText.Text = string.format("%s [Slasher]%s", info.playerName, distText)
                                
                                if distance < 125 then
                                    espText.TextColor3 = Color3.fromRGB(255, 0, 0)
                                elseif distance <= 215 then
                                    espText.TextColor3 = Color3.fromRGB(255, 255, 0)
                                else
                                    espText.TextColor3 = Color3.fromRGB(0, 255, 0)
                                end
                            end
                        elseif info.type == "Escape" then
                            local espText = info.gui:FindFirstChild("ESP_Text")
                            if espText then
                                local distText = (distance > 2000) and "" or string.format(" (%.0fm)", distance)
                                espText.Text = string.format("Escape%s", distText)
                            end
                        elseif info.type == "Coin" then
                            itemCounts.coins = itemCounts.coins + 1
                        elseif info.type == "Film" then
                            itemCounts.films = itemCounts.films + 1
                        elseif info.type == "Medkit" then
                            itemCounts.medkits = itemCounts.medkits + 1
                        elseif info.type == "Battery" then
                            itemCounts.batterys = itemCounts.batterys + 1
                        elseif info.type == "Bandage" then
                            itemCounts.bandages = itemCounts.bandages + 1
                        end
                    else
                        removeESP(obj)
                    end
                end
            end
            
            if statsUI and statsUI.label and statsUI.slasherLabel then
                statsUI.label.Text = string.format("C: %d | F: %d | M: %d | B: %d | BD: %d",
                    itemCounts.coins, itemCounts.films, itemCounts.medkits, itemCounts.batterys, itemCounts.bandages)
                statsUI.slasherLabel.Text = string.format("Slasher Type: %s | Ch: %s", slasherSortType, slasherChainsawCount)
            end
        end, "espUpdateLoop")
    end
end)

