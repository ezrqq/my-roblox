local function triggerNearbyPrompts()
local currentTime = tick()
local effectiveDelay = CONFIG.PickupDelay + CONFIG.PickupDelayIncrement
if currentTime - lastPickupTime < effectiveDelay then return end
local character = LocalPlayer.Character
if not character then return end
local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
if not humanoidRootPart then return end
local hrpPosition = humanoidRootPart.Position
local itemsFolders = {}
local itemsToCheck = {}
local allItems = {}
for _, itemData in ipairs(ITEM_SETTINGS) do
allItems[#allItems + 1] = {
folderPath = itemData.folderPath,
type = itemData.type,
enabled = state[itemData.stateKey]
}
end
for _, itemData in ipairs(allItems) do
if itemData.enabled then
local folder = findInPath(Workspace, itemData.folderPath)
if folder then
table.insert(itemsFolders, {folder = folder, type = itemData.type})
end
end
end
for _, folderData in ipairs(itemsFolders) do
for _, item in ipairs(folderData.folder:GetChildren()) do
local prompt = nil
for _, descendant in ipairs(item:GetDescendants()) do
if descendant:IsA("ProximityPrompt") and descendant.Enabled then
prompt = descendant
break
end
end
if prompt and not pickedUpPrompts[prompt] then
local itemPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart", true)
if itemPart then
local distance = (itemPart.Position - hrpPosition).Magnitude
if distance < 100 then
table.insert(itemsToCheck, {
item = item,
prompt = prompt,
distance = distance,
type = folderData.type
})
end
end
end
end
end
if #itemsToCheck > 0 then
table.sort(itemsToCheck, function(a, b)
return a.distance < b.distance
end)
local closest = itemsToCheck[1]
lastPickupTime = currentTime
pickedUpPrompts[closest.prompt] = true
task.spawn(function()
task.wait(CONFIG.PromptActivationDelay)
if not closest or not closest.prompt or not closest.prompt.Parent then
if closest and closest.prompt then
pickedUpPrompts[closest.prompt] = nil
end
return
end
local success = pcall(function()
if fireproximityprompt then
fireproximityprompt(closest.prompt)
else
if closest.prompt and closest.prompt.Parent then
closest.prompt:InputHoldBegin()
task.wait(closest.prompt.HoldDuration or 0.5)
closest.prompt:InputHoldEnd()
end
end
end)
task.delay(2, function()
pickedUpPrompts[closest.prompt] = nil
end)
end)
end
end
local pickupTask = task.spawn(function()
while task.wait(0.05) do
if state.autoPickup then
pcall(triggerNearbyPrompts)
end
end
end)
pickupConnection = {
task = pickupTask,
Disconnect = function() task.cancel(pickupTask) end
}
table.insert(connections, pickupConnection)
end
local function createRoundedFrame(size, position, parent, withGlow, backgroundTransparency, backgroundColor, cornerRadius, zIndex)
local frame = Instance.new("Frame")
frame.Size = size or UDim2.new(1, 0, 0, 40)
frame.Position = position or UDim2.new(0, 0, 0, 0)
frame.Parent = parent
frame.BackgroundColor3 = backgroundColor or Color3.fromRGB(25, 25, 25)
frame.BackgroundTransparency = backgroundTransparency or 0.5
frame.BorderSizePixel = 0
if zIndex then frame.ZIndex = zIndex end
local corner = Instance.new("UICorner")
corner.CornerRadius = cornerRadius or CONFIG.Visual.CornerRadius
corner.Parent = frame
if withGlow then
local stroke = Instance.new("UIStroke")
stroke.Color = CONFIG.Visual.GlowColor
stroke.Transparency = CONFIG.Visual.GlowTransparency
stroke.Thickness = CONFIG.Visual.GlowThickness * (withGlow.thicknessMultiplier or 1)
stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
stroke.LineJoinMode = Enum.LineJoinMode.Round
stroke.Parent = frame
end
return frame
end
local function setupDynamicGlow()
local cycleDuration = 2.5
local minColor = Color3.fromRGB(150, 150, 150)
local maxColor = CONFIG.Visual.GlowColor
local runningTask = task.spawn(function()
while task.wait(1/60) do
local timeFactor = (tick() % cycleDuration) / cycleDuration
local progress = 0.5 * math.sin(timeFactor * math.pi * 2) + 0.5
local newColor = minColor:Lerp(maxColor, progress)
for i = #mainGlowFrames, 1, -1 do
local frame = mainGlowFrames[i]
if frame and frame.Parent then
local stroke = frame:FindFirstChildOfClass("UIStroke")
if stroke then
stroke.Color = newColor
end
else
table.remove(mainGlowFrames, i)
end
end
end
end)
return runningTask
end
