RunService.Heartbeat:Connect(function()
if not (state.showSlasher or state.showSurvivors or state.showFriends or state.showEscapes or state.showBatterys or state.showBandages) then
return
end
local char = LocalPlayer.Character
if not char then
return
end
local hrp = char:FindFirstChild("HumanoidRootPart")
if not hrp then
return
end
local hrpPosition = hrp.Position
itemCounts = {
coins = 0,
films = 0,
medkits = 0,
batterys = 0,
bandages = 0
}
for obj, info in pairs(espHandles) do
if info and info.adornee and info.gui and info.gui.Parent then
local adornee = info.adornee
if adornee and adornee.Parent then
if info.type == "Slasher" then
local espText = info.gui:FindFirstChild("ESP_Text")
if espText and info.playerName then
local dist = (adornee.Position - hrpPosition).Magnitude
espText.Text = string.format("%s [Slasher] (%.0fm)", info.playerName, dist)
if dist < 125 then
espText.TextColor3 = Color3.fromRGB(255, 0, 0)
elseif dist <= 215 then
espText.TextColor3 = Color3.fromRGB(255, 255, 0)
else
espText.TextColor3 = Color3.fromRGB(0, 255, 0)
end
end
elseif info.type == "Escape" then
local espText = info.gui:FindFirstChild("ESP_Text")
if espText then
local dist = (adornee.Position - hrpPosition).Magnitude
espText.Text = string.format("Escape (%.0fm)", dist)
end
elseif info.type == "Coin" then
itemCounts.coins = itemCounts.coins + 1
elseif info.type == "Film" then
itemCounts.films = itemCounts.films + 1
elseif info.type == "Medkit" then
itemCounts.medkits = itemCounts.medkits + 1
elseif info.type == "Battery" then
itemCounts.batterys = itemCounts.batterys + 1
elseif info.type == "Bandage" then
itemCounts.bandages = itemCounts.bandages + 1
end
else
removeESP(obj)
end
end
end
if statsUI and statsUI.label then
statsUI.label.Text = string.format("C: %d | F: %d | M: %d | B: %d | BD: %d",
itemCounts.coins, itemCounts.films, itemCounts.medkits, itemCounts.batterys, itemCounts.bandages)
end
end)
