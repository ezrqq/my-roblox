--[[ UTILITY FUNCTIONS ]]
local function safeCall(func, context)
    local success, err = pcall(func)
    if not success then
        warn(string.format("[STN] Error in %s: %s", context or "unknown", tostring(err)))
        warn("Stack Traceback:\n" .. debug.traceback(tostring(err), 2))
    end
    return success
end

local function findInPath(root, path)
    if not path then return nil end
    local obj = root
    for _, name in ipairs(path) do
        if not obj then return nil end
        obj = obj:FindFirstChild(name)
    end
    return obj
end

local function findAdornee(obj)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart end
        local hrp = obj:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp end
        
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("BasePart") then return child end
        end
    end
    
    for _, child in ipairs(obj:GetDescendants()) do
        if child:IsA("BasePart") then return child end
    end
    
    return nil
end

local function findStats(model)
    if not model then return nil end
    local stats = model:FindFirstChild("Stats")
    if stats then return stats end
    
    local kit = model:FindFirstChild("Kit")
    if kit then
        stats = kit:FindFirstChild("Stats")
        if stats then return stats end
    end
    
    return nil
end

--[[ ESP MANAGEMENT ]]
local function removeESP(obj)
    if not obj then return end
    local info = espHandles[obj]
    if info then
        safeCall(function()
            if info.gui then info.gui:Destroy() end
            if info.box then info.box:Destroy() end
        end, "removeESP")
        espHandles[obj] = nil
        return true
    end
    return false
end

local function clearAllESP()
    for obj in pairs(espHandles) do
        removeESP(obj)
    end
end

local function createESP(obj, text, color, itemType, isSlasher, transparency)
    if not obj or espHandles[obj] then return end
    
    local adornee = findAdornee(obj)
    if not adornee then return end
    
    local success = safeCall(function()
        local boxScale = isSlasher and CONFIG.SlasherBoxScale or CONFIG.BoxScale
        
        local gui = Instance.new("BillboardGui")
        gui.Name = "ESP_Label"
        gui.Adornee = adornee
        gui.Size = UDim2.new(0, 120, 0, 20)
        gui.AlwaysOnTop = true
        gui.StudsOffset = Vector3.new(0, 3, 0)
        gui.ResetOnSpawn = false
        gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        gui.Parent = obj
        
        local label = Instance.new("TextLabel")
        label.Name = "ESP_Text"
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextScaled = true
        label.Font = Enum.Font.Gotham
        label.TextSize = 10
        label.TextColor3 = color
        label.TextStrokeTransparency = 0.7
        label.Parent = gui
        
        local box = Instance.new("BoxHandleAdornment")
        box.Name = "ESP_Box"
        box.Adornee = adornee
        box.AlwaysOnTop = true
        box.ZIndex = 1
        box.Color3 = color
        box.Transparency = transparency or CONFIG.BoxTransparency
        box.Size = (adornee.Size or Vector3.new(2, 2, 2)) * boxScale
        box.Parent = adornee
        
        local playerName = nil
        if itemType == "Slasher" then
            playerName = text:match("^(.-)%[Slasher%]")
        end
        
        espHandles[obj] = {
            gui = gui,
            box = box,
            type = itemType or " ",
            adornee = adornee,
            originalParent = obj.Parent,
            playerName = playerName
        }
    end, "createESP")
    
    return success
end

--[[ PROMPT MONITORING ]]
local function isPromptEnabled(prompt)
    return prompt and prompt.Enabled
end

local function monitorPrompt(obj, prompt)
    if not obj or not prompt then return end
    
    local function onPromptChange()
        if not isPromptEnabled(prompt) then
            removeESP(obj)
        end
    end
    
    local connection = prompt:GetPropertyChangedSignal("Enabled"):Connect(onPromptChange)
    itemPromptConnections[obj] = connection
    onPromptChange()
end

local function stopMonitoringPrompt(obj)
    local connection = itemPromptConnections[obj]
    if connection then
        connection:Disconnect()
        itemPromptConnections[obj] = nil
    end
end

--[[ PLAYER TRACKING ]]
local function isFriendOfLocal(plr)
    return plr and friendsCache[plr.UserId] == true
end

local function getPlayerTeamColor(player)
    if not player.Character then return nil end
    local stats = player.Character:FindFirstChild("Kit") and player.Character.Kit:FindFirstChild("Stats")
    if not stats then return nil end
    local teamColor = stats:FindFirstChild("TeamColor")
    return teamColor and teamColor.Value
end

local function updateCharacterESP(model)
    safeCall(function()
        if not model or model == LocalPlayer.Character then
            removeESP(model)
            return
        end
        
        local player = Players:GetPlayerFromCharacter(model)
        if not player then
            removeESP(model)
            return
        end
        
        local isFriend = isFriendOfLocal(player)
        local stats = findStats(model)
        
        if stats then
            local typ = stats:FindFirstChild("Type")
            if typ and typ:IsA("StringValue") then
                local isSlasher = (typ.Value:lower() == "slasher")
                if isSlasher and state.showSlasher then
                    createESP(model, player.Name .. " [Slasher] ", CONFIG.PlayerColors.Slasher, "Slasher", true)
                    return
                end
            end
        end
        
        local teamColor = getPlayerTeamColor(player)
        if not teamColor then
            removeESP(model)
            return
        end
        
        local isSurvivor = (teamColor == Color3.new(0, 1, 0))
        
        if isFriend and state.showFriends then
            createESP(model, "Friend ", Color3.fromRGB(0, 200, 255), "Friend", false)
        elseif isSurvivor and state.showSurvivors and not isFriend then
            createESP(model, player.Name .. " [Survivor] ", CONFIG.PlayerColors.Survivor, "Survivor", false)
        else
            removeESP(model)
        end
    end, "updateCharacterESP")
end

--[[ FOLDER MONITORING ]]
local function disconnectMonitors()
    for _, connection in pairs(monitoredFolders) do
        if connection and connection.Disconnect then
            connection:Disconnect()
        end
    end
    monitoredFolders = {}
    
    for obj, connection in pairs(itemPromptConnections) do
        if connection and connection.Disconnect then
            connection:Disconnect()
        end
    end
    itemPromptConnections = {}
end

local function setupMonitor(folder, itemType, color, transparency)
    if not folder then return end
    
    local function handleChild(child)
        if not child then return end
        
        local prompt = nil
        for _, descendant in ipairs(child:GetDescendants()) do
            if descendant:IsA("ProximityPrompt") then
                prompt = descendant
                break
            end
        end
        
        if prompt then
            monitorPrompt(child, prompt)
        end
        
        createESP(child, itemType, color, itemType, false, transparency)
        
        local con = child.AncestryChanged:Connect(function(parent)
            if not parent or parent ~= folder then
                removeESP(child)
                stopMonitoringPrompt(child)
            end
        end)
        table.insert(connections, con)
    end
    
    for _, child in ipairs(folder:GetChildren()) do
        handleChild(child)
    end
    
    local addedCon = folder.ChildAdded:Connect(handleChild)
    local removedCon = folder.ChildRemoved:Connect(function(child)
        removeESP(child)
        stopMonitoringPrompt(child)
    end)
    
    table.insert(monitoredFolders, addedCon)
    table.insert(monitoredFolders, removedCon)
    table.insert(connections, addedCon)
    table.insert(connections, removedCon)
end

local function detectAndSetupMonitors()
    disconnectMonitors()
    
    for _, itemData in ipairs(ITEM_SETTINGS) do
        if state[itemData.stateKey] then
            local folder = findInPath(Workspace, itemData.folderPath)
            if folder then
                setupMonitor(folder, itemData.type, itemData.color, itemData.transparency)
            end
        end
    end
end

local function updateAllESP()
    if isUpdatingESP then return end
    isUpdatingESP = true
    
    safeCall(function()
        clearAllESP()
        detectAndSetupMonitors()
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                updateCharacterESP(player.Character)
            end
        end
    end, "updateAllESP")
    
    isUpdatingESP = false
end

