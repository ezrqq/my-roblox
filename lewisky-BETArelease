local function getPlayerTeamColor(player)
if not player.Character then return nil end
local stats = player.Character:FindFirstChild("Kit") and player.Character.Kit:FindFirstChild("Stats")
if not stats then return nil end
local teamColor = stats:FindFirstChild("TeamColor")
return teamColor and teamColor.Value
end
local function findStats(model)
    if not model then return nil end
    local stats = model:FindFirstChild("Stats")
    if stats then return stats end
    local kit = model:FindFirstChild("Kit")
    if kit then
        stats = kit:FindFirstChild("Stats")
        if stats then return stats end
    end
    return nil
end
local function updateCharacterESP(model)
local success, err = pcall(function()
if not model or model == LocalPlayer.Character then
removeESP(model)
return
end
local player = Players:GetPlayerFromCharacter(model)
if not player then
removeESP(model)
return
end
local isFriend = player and isFriendOfLocal(player)
local stats = findStats(model)
if stats then
local typ = stats:FindFirstChild("Type")
if typ and typ:IsA("StringValue") then
local isSlasher = (typ.Value:lower() == "slasher")
local playerName = player.Name
if isSlasher and state.showSlasher then
createESP(model, playerName .. " [Slasher] ", CONFIG.PlayerColors.Slasher, "Slasher", true)
return
end
end
end
local teamColor = getPlayerTeamColor(player)
if not teamColor then
removeESP(model)
return
end
local isSurvivor = (teamColor == Color3.new(0, 1, 0))
if isFriend and state.showFriends then
createESP(model, "Friend ", Color3.fromRGB(0, 200, 255), "Friend", false)
elseif isSurvivor and state.showSurvivors and not isFriend then
createESP(model, player.Name .. " [Survivor] ", CONFIG.PlayerColors.Survivor, "Survivor", false)
else
removeESP(model)
end
end)
if not success then warn("[ESP] updateCharacterESP Error:", err) end
end
