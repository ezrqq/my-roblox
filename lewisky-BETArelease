--[[ CLEANUP FUNCTION ]]
local function cleanup()
    for _, taskThread in pairs(runningTasks) do
        if type(taskThread) == "thread" then
            task.cancel(taskThread)
        end
    end
    runningTasks = {}
    
    for _, con in ipairs(connections) do
        if con and con.Disconnect then
            con:Disconnect()
        elseif con and con.task and con.Disconnect then
            con:Disconnect()
        end
    end
    connections = {}
    
    disconnectMonitors()
    
    safeCall(function()
        Lighting.Brightness = originalLighting.Brightness
        Lighting.FogEnd = originalLighting.FogEnd
        Lighting.GlobalShadows = originalLighting.GlobalShadows
        Lighting.Technology = originalLighting.Technology
        Lighting.EnvironmentDiffuseScale = originalLighting.EnvDiffuse
        Lighting.EnvironmentSpecularScale = originalLighting.EnvSpecular
        Lighting.ClockTime = originalLighting.ClockTime
        Lighting.Ambient = originalLighting.Ambient
        Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
        
        if Lighting.Atmosphere then
            Lighting.Atmosphere.Density = originalLighting.AtmosphereDensity
        end
        
        if Lighting:FindFirstChild("DefaultBloom") then
            Lighting.DefaultBloom.Enabled = originalLighting.BloomEnabled
        end
        
        if Lighting:FindFirstChild("DefaultBlur") then
            Lighting.DefaultBlur.Enabled = originalLighting.BlurEnabled
        end
        
        local genophageCC = Lighting:FindFirstChild("GenophageColorCorrection")
        if genophageCC and originalLighting.GenophageEnabled then
            genophageCC.Enabled = originalLighting.GenophageEnabled
            genophageCC.Brightness = originalLighting.GenophageBrightness
        end
    end, "cleanup")
    
    clearAllESP()
    
    if statsUI then
        statsUI.gui:Destroy()
        statsUI = nil
    end
    
    local oldGui = PlayerGui:FindFirstChild("ESP_UI")
    if oldGui then oldGui:Destroy() end
    
    print("[STN] Cleanup completed successfully")
end

