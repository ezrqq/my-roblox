local function ESP(obj, color)
    if obj:FindFirstChild("H") then return end
    local h = Instance.new("Highlight")
    h.Name = "H"
    h.Adornee = obj
    h.FillColor = color
    h.OutlineColor = color
    h.FillTransparency = 0.9
    h.OutlineTransparency = 0
    h.Parent = obj
end

local function removeESP(obj)
    if not obj then return end
    local h = obj:FindFirstChild("H")
    if h then
        h:Destroy()
    end
end

local function addHookESP(hookModel, color)
    if hookModel:FindFirstChild("Model") then
        for _, part in ipairs(hookModel.Model:GetDescendants()) do
            if part:IsA("MeshPart") then
                ESP(part, color)
            end
        end
    end
    if hookModel:FindFirstChild("Cartoony Blood Puddle") then
        ESP(hookModel["Cartoony Blood Puddle"], color)
    end
end

local function removeHookESP(hookModel)
     if hookModel:FindFirstChild("Model") then
        for _, part in ipairs(hookModel.Model:GetDescendants()) do
            if part:IsA("MeshPart") then
                removeESP(part)
            end
        end
    end
    if hookModel:FindFirstChild("Cartoony Blood Puddle") then
        removeESP(hookModel["Cartoony Blood Puddle"])
    end
end

local function createRoundedFrame(size, position, parent, withGlow, backgroundTransparency, backgroundColor, cornerRadius, zIndex)
    local frame = Instance.new("Frame")
    frame.Size = size or UDim2.new(1, 0, 0, 40)
    frame.Position = position or UDim2.new(0, 0, 0, 0)
    frame.Parent = parent
    frame.BackgroundColor3 = backgroundColor or Color3.fromRGB(25, 25, 25)
    frame.BackgroundTransparency = backgroundTransparency or 0.5
    frame.BorderSizePixel = 0
    if zIndex then frame.ZIndex = zIndex end
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = cornerRadius or CONFIG.Visual.CornerRadius
    corner.Parent = frame
    
    if withGlow and state.enableGlow then
        local stroke = Instance.new("UIStroke")
        stroke.Color = CONFIG.Visual.GlowColor
        stroke.Transparency = CONFIG.Visual.GlowTransparency
        stroke.Thickness = CONFIG.Visual.GlowThickness * (withGlow.thicknessMultiplier or 1)
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.LineJoinMode = Enum.LineJoinMode.Round
        stroke.Parent = frame
        
        frame:SetAttribute("HasGlow", true)
    end
    
    return frame
end

local function updateGlowVisibility()
    for _, frame in ipairs(mainGlowFrames) do
        if frame and frame.Parent then
            local stroke = frame:FindFirstChildOfClass("UIStroke")
            if stroke then
                stroke.Enabled = state.enableGlow
            end
        end
    end
end

local function setupDynamicGlow()
    if not state.enableGlow then return end
    
    local cycleDuration = 2.5
    local minColor = Color3.fromRGB(150, 150, 150)
    local maxColor = CONFIG.Visual.GlowColor
    
    local runningTask = task.spawn(function()
        while task.wait(1/60) do
            if not state.enableGlow then
                task.wait(1)
                continue
            end
            
            local timeFactor = (tick() % cycleDuration) / cycleDuration
            local progress = 0.5 * math.sin(timeFactor * math.pi * 2) + 0.5
            local newColor = minColor:Lerp(maxColor, progress)
            
            for i = #mainGlowFrames, 1, -1 do
                local frame = mainGlowFrames[i]
                if frame and frame.Parent then
                    local stroke = frame:FindFirstChildOfClass("UIStroke")
                    if stroke then
                        stroke.Color = newColor
                    end
                else
                    table.remove(mainGlowFrames, i)
                end
            end
        end
    end)
    
    return runningTask
end

