local mapInstance = workspace:WaitForChild("Map", 30)

local folder = {
    ["Generator"] = mapInstance,
    ["Gate"] = mapInstance,
    ["Pallet"] = mapInstance,
    ["Window"] = mapInstance,
    ["Pumpkin"] = mapInstance and mapInstance:findFirstChild("Pumpkins"),
    ["Hook"] = mapInstance
}

local objectCache = {
    Generator = {},
    Gate = {},
    Pallet = {},
    Window = {},
    Hook = {},
    Pumpkin = {}
}

local function refreshObjectCaches()
    pcall(function()
        local newCaches = {Generator = {}, Gate = {}, Pallet = {}, Window = {}, Hook = {}, Pumpkin = {}}
        
        for t, f in pairs(folder) do
            if f and f:IsA("Instance") then
                for _, obj in ipairs(f:GetDescendants()) do
                    if t == "Hook" and obj.Name == "Hook" then
                        table.insert(newCaches.Hook, obj)
                    elseif obj.Name == (t == "Pallet" and "Palletwrong" or t) then
                        if newCaches[t] then
                            table.insert(newCaches[t], obj)
                        end
                    end
                end
            end
        end
        objectCache = newCaches
    end)
end

runningTasks.cacheRefresh = task.spawn(function()
    while task.wait(5) do
        refreshObjectCaches()
    end
end)

runningTasks.espUpdate = task.spawn(function()
    while task.wait(0.25) do
        
        pcall(function()
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Team then
                    
                    local success, isFriend = pcall(function() return LocalPlayer:IsFriendsWith(p.UserId) end)
                    
                    if success and isFriend and Hook.Players["Friends"].On then
                        ESP(p.Character, Hook.Players["Friends"].Color)
                    elseif p.Team.Name == "Killer" then
                        if Hook.Players["Killer"].On then
                            ESP(p.Character, Hook.Players["Killer"].Color)
                        else
                            removeESP(p.Character)
                        end
                    elseif p.Team.Name == "Survivors" then
                        if Hook.Players["Survivor"].On then
                            ESP(p.Character, Hook.Players["Survivor"].Color)
                        else
                            removeESP(p.Character)
                        end
                    else
                        removeESP(p.Character)
                    end
                elseif p.Character then
                     removeESP(p.Character)
                end
            end
        end)
        
        pcall(function()
            for t, objectList in pairs(objectCache) do
                local state = Hook.Objects[t].On
                local color = Hook.Objects[t].Color
                
                for _, obj in ipairs(objectList) do
                     if obj and obj.Parent then
                        if t == "Hook" then
                            if state then addHookESP(obj, color) else removeHookESP(obj) end
                        else
                            if state then ESP(obj, color) else removeESP(obj) end
                        end
                    end
                end
            end
        end)
    end
end)

local function cleanup()
    
    for _, taskThread in pairs(runningTasks) do
        if type(taskThread) == "thread" then
            task.cancel(taskThread)
        end
    end
    runningTasks = {}
    
    for _, con in ipairs(connections) do
        if con and con.Disconnect then
            con:Disconnect()
        end
    end
    connections = {}
    
    local oldGui = PlayerGui:FindFirstChild("ESP_UI")
    if oldGui then oldGui:Destroy() end
    
end

table.insert(connections, Players.PlayerRemoving:Connect(function(player)
    if player == LocalPlayer then
        cleanup()
    end
end))

