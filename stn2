--[[ SAVE / LOAD ]]
local function canUseFiles()
    return type(writefile) == "function"
       and type(readfile)  == "function"
       and type(isfile)    == "function"
end

local function saveSettings()
    if not canUseFiles() then return end
    local colorsRaw = {}
    for k, c in pairs(customColors) do
        colorsRaw[k] = {r = math.floor(c.R*255+0.5), g = math.floor(c.G*255+0.5), b = math.floor(c.B*255+0.5)}
    end
    local data = {state = state, colors = colorsRaw}
    pcall(writefile, CONFIG_PATH, HttpService:JSONEncode(data))
end

local function loadSettings()
    if not canUseFiles() then return end
    local ok1, raw = pcall(isfile, CONFIG_PATH)
    if not ok1 or not raw then return end
    local ok2, txt = pcall(readfile, CONFIG_PATH)
    if not ok2 then return end
    local ok3, data = pcall(HttpService.JSONDecode, HttpService, txt)
    if not ok3 or type(data) ~= "table" then return end

    if type(data.state) == "table" then
        for k, v in pairs(data.state) do
            if state[k] ~= nil and type(v) == type(state[k]) then
                state[k] = v
            end
        end
    end

    if type(data.colors) == "table" then
        for typeName, c in pairs(data.colors) do
            if customColors[typeName] ~= nil and type(c) == "table" then
                local r = type(c.r)=="number" and math.clamp(c.r,0,255) or 255
                local g = type(c.g)=="number" and math.clamp(c.g,0,255) or 255
                local b = type(c.b)=="number" and math.clamp(c.b,0,255) or 255
                customColors[typeName] = Color3.fromRGB(r, g, b)
            end
        end
    end
end

--[[ UTILITY ]]
local function safeCall(func, context)
    local ok, err = pcall(func)
    if not ok then
        warn(string.format("[STN] Error in %s: %s", context or "unknown", tostring(err)))
    end
    return ok
end

local function findInPath(root, path)
    if not path then return nil end
    local obj = root
    for _, name in ipairs(path) do
        if not obj then return nil end
        obj = obj:FindFirstChild(name)
    end
    return obj
end

local function findAdornee(obj)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart end
        local hrp = obj:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp end
    end
    for _, child in ipairs(obj:GetDescendants()) do
        if child:IsA("BasePart") then return child end
    end
    return nil
end

local function findStats(model)
    if not model then return nil end
    local s = model:FindFirstChild("Stats")
    if s then return s end
    local kit = model:FindFirstChild("Kit")
    if kit then return kit:FindFirstChild("Stats") end
    return nil
end

--[[ ESP ]]
local function removeESP(obj)
    if not obj then return false end
    local info = espHandles[obj]
    if not info then return false end
    safeCall(function()
        if info.gui     and info.gui.Parent     then info.gui:Destroy()     end
        if info.outline and info.outline.Parent then info.outline:Destroy() end
    end, "removeESP")
    espHandles[obj] = nil
    return true
end

local function clearAllESP()
    local keys = {}
    for obj in pairs(espHandles) do keys[#keys+1] = obj end
    for _, obj in ipairs(keys) do removeESP(obj) end
end

local function createESP(obj, text, color, itemType, isPlayer, cachedPrompt)
    if not obj or espHandles[obj] then return end
    local adornee = findAdornee(obj)
    if not adornee then return end

    local ok = safeCall(function()
        local gui = Instance.new("BillboardGui")
        gui.Name           = "ESP_Label"
        gui.Adornee        = adornee
        gui.Size           = UDim2.new(0, 120, 0, 20)
        gui.AlwaysOnTop    = true
        gui.LightInfluence = 0
        gui.StudsOffset    = Vector3.new(0, isPlayer and 3.5 or 2.5, 0)
        gui.ResetOnSpawn   = false
        gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        gui.Parent         = obj

        local label = Instance.new("TextLabel")
        label.Name                   = "ESP_Text"
        label.Size                   = UDim2.new(1,0,1,0)
        label.BackgroundTransparency = 1
        label.Text                   = text
        label.TextScaled             = true
        label.Font                   = Enum.Font.GothamBold
        label.TextColor3             = color
        label.TextStrokeTransparency = 0.5
        label.Parent                 = gui

        local outline = Instance.new("SelectionBox")
        outline.Name                = "ESP_Outline"
        outline.Adornee             = obj:IsA("Model") and obj or adornee
        outline.Color3              = color
        outline.LineThickness       = CONFIG.OutlineThickness
        outline.SurfaceTransparency = CONFIG.OutlineSurfaceTrans
        outline.SurfaceColor3       = color
        outline.Parent              = obj   -- auto-destroyed with obj

        local playerName = nil
        if     itemType == "Slasher"  then playerName = text:match("^(.-)%s*%[Slasher%]")
        elseif itemType == "Survivor" then playerName = text:match("^(.-)%s*%[Survivor%]")
        elseif itemType == "Friend"   then playerName = text:match("^Friend%s+(.*)")
        end

        local outlineTarget = obj:IsA("Model") and obj or adornee

        espHandles[obj] = {
            gui          = gui,
            outline      = outline,
            espLabel     = label,
            type         = itemType or "Unknown",
            adornee      = adornee,
            outlineTarget= outlineTarget,
            playerName   = playerName,
            stats        = findStats(obj),
            prompt       = cachedPrompt,
            lodLevel     = LOD_FULL,
        }
    end, "createESP")

    return ok
end

--[[ PROMPT MONITORING ]]
local function isPromptEnabled(prompt)
    return prompt ~= nil and prompt.Enabled
end

local function monitorPrompt(obj, prompt)
    if not obj or not prompt then return end
    local old = itemPromptConnections[obj]
    if old then old:Disconnect() end
    local con = prompt:GetPropertyChangedSignal("Enabled"):Connect(function()
        if not isPromptEnabled(prompt) then removeESP(obj) end
    end)
    itemPromptConnections[obj] = con
    if not isPromptEnabled(prompt) then removeESP(obj) end
end

local function stopMonitoringPrompt(obj)
    local con = itemPromptConnections[obj]
    if con then con:Disconnect(); itemPromptConnections[obj] = nil end
end

--[[ PLAYER TRACKING ]]
local function isFriendOfLocal(plr)
    return plr ~= nil and friendsCache[plr.UserId] == true
end

local function getPlayerTeamColor(player)
    if not player or not player.Character then return nil end
    local kit = player.Character:FindFirstChild("Kit")
    if not kit then return nil end
    local stats = kit:FindFirstChild("Stats")
    if not stats then return nil end
    local tc = stats:FindFirstChild("TeamColor")
    return tc and tc.Value
end

local function updateCharacterESP(model)
    safeCall(function()
        if not model or model == LocalPlayer.Character then removeESP(model) return end
        local player = Players:GetPlayerFromCharacter(model)
        if not player then removeESP(model) return end

        local isFriend = isFriendOfLocal(player)
        local stats    = findStats(model)

        if stats then
            local typ = stats:FindFirstChild("Type")
            if typ and typ:IsA("StringValue") then
                if typ.Value:lower() == "slasher" then
                    if state.showSlasher then
                        createESP(model, player.Name.." [Slasher]", customColors.Slasher, "Slasher", true)
                    else
                        removeESP(model)
                    end
                    return
                end
            end
        end

        local teamColor = getPlayerTeamColor(player)
        if not teamColor then removeESP(model) return end

        local r, g, b    = teamColor.R, teamColor.G, teamColor.B
        local isSurvivor = r < 0.1 and g > 0.9 and b < 0.1

        if isFriend and state.showFriends then
            createESP(model, "Friend "..player.Name, customColors.Friend, "Friend", true)
        elseif isSurvivor and state.showSurvivors and not isFriend then
            createESP(model, player.Name.." [Survivor]", customColors.Survivor, "Survivor", true)
        else
            removeESP(model)
        end
    end, "updateCharacterESP")
end

--[[ FOLDER MONITORING ]]
local function disconnectMonitors()
    for _, con in pairs(monitoredFolders) do
        if con and con.Disconnect then con:Disconnect() end
    end
    monitoredFolders = {}
    for _, con in pairs(itemPromptConnections) do
        if con and con.Disconnect then con:Disconnect() end
    end
    itemPromptConnections = setmetatable({}, {__mode = "k"})
end

local function setupMonitor(folder, itemType)
    if not folder then return end

    local function handleChild(child)
        if not child then return end
        local prompt = child:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then monitorPrompt(child, prompt) end
        createESP(child, itemType, customColors[itemType] or Color3.new(1,1,1), itemType, false, prompt)
        local con = child.AncestryChanged:Connect(function(_, newParent)
            if not newParent then removeESP(child); stopMonitoringPrompt(child) end
        end)
        table.insert(connections, con)
    end

    for _, child in ipairs(folder:GetChildren()) do handleChild(child) end

    local addedCon   = folder.ChildAdded:Connect(handleChild)
    local removedCon = folder.ChildRemoved:Connect(function(child)
        removeESP(child); stopMonitoringPrompt(child)
    end)
    table.insert(monitoredFolders, addedCon)
    table.insert(monitoredFolders, removedCon)
    table.insert(connections, addedCon)
    table.insert(connections, removedCon)
end

local function detectAndSetupMonitors()
    disconnectMonitors()
    for _, itemData in ipairs(ITEM_SETTINGS) do
        if state[itemData.stateKey] then
            local folder = findInPath(Workspace, itemData.folderPath)
            if folder then setupMonitor(folder, itemData.type) end
        end
    end
end

local function updateAllESP()
    if isUpdatingESP then return end
    isUpdatingESP = true
    safeCall(function()
        clearAllESP()
        detectAndSetupMonitors()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                updateCharacterESP(player.Character)
            end
        end
    end, "updateAllESP")
    isUpdatingESP = false
end

--[[ ROUND DETECTION ]]
local function watchForNewRounds()
    local function check()
        if Workspace:FindFirstChild("TempMap") then task.delay(0.8, updateAllESP) end
    end
    table.insert(connections, Workspace.ChildAdded:Connect(function(child)
        if child.Name == "TempMap" then check() end
    end))
    check()
end

--[[ FRIENDS CACHE ]]
local function refreshFriends()
    friendsCache = setmetatable({}, {__mode = "kv"})
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            safeCall(function()
                if LocalPlayer:IsFriendsWith(player.UserId) then
                    friendsCache[player.UserId] = true
                end
            end, "refreshFriends")
        end
    end
end

--[[ LIGHTING ]]
local function applyFullbright()
    safeCall(function()
        if state.fullbright then
            Lighting.Brightness               = 2
            Lighting.FogEnd                   = 1e9
            Lighting.GlobalShadows            = false
            Lighting.Technology               = Enum.Technology.ShadowMap
            Lighting.EnvironmentDiffuseScale  = 1
            Lighting.EnvironmentSpecularScale = 1
        else
            Lighting.Brightness               = originalLighting.Brightness
            Lighting.FogEnd                   = originalLighting.FogEnd
            Lighting.GlobalShadows            = originalLighting.GlobalShadows
            Lighting.Technology               = originalLighting.Technology
            Lighting.EnvironmentDiffuseScale  = originalLighting.EnvDiffuse
            Lighting.EnvironmentSpecularScale = originalLighting.EnvSpecular
        end
    end, "applyFullbright")
end

local function setupFullbrightProtection()
    local function r() if state.fullbright then applyFullbright() end end
    table.insert(connections, Lighting:GetPropertyChangedSignal("Brightness"):Connect(r))
    table.insert(connections, Lighting:GetPropertyChangedSignal("FogEnd"):Connect(r))
    table.insert(connections, Lighting:GetPropertyChangedSignal("GlobalShadows"):Connect(r))
    table.insert(connections, Lighting:GetPropertyChangedSignal("Technology"):Connect(r))
end

local function applyEnhancedFullbright()
    safeCall(function()
        if Lighting.Atmosphere then
            Lighting.Atmosphere.Density = state.fullbrightEnhanced and 0 or originalLighting.AtmosphereDensity
        end
        if state.fullbrightEnhanced then
            Lighting.ClockTime      = 14
            Lighting.Ambient        = Color3.fromRGB(200,200,200)
            Lighting.OutdoorAmbient = Color3.fromRGB(200,200,200)
        else
            Lighting.ClockTime      = originalLighting.ClockTime
            Lighting.Ambient        = originalLighting.Ambient
            Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
        end
        local bloom = Lighting:FindFirstChild("DefaultBloom")
        if bloom then bloom.Enabled = not state.disableBloom end
        local blur  = Lighting:FindFirstChild("DefaultBlur")
        if blur  then blur.Enabled  = not state.disableBlur  end
    end, "applyEnhancedFullbright")
end

local function setupEnhancedFullbrightProtection()
    local function r() if state.fullbrightEnhanced then applyEnhancedFullbright() end end
    if Lighting.Atmosphere then
        table.insert(connections, Lighting.Atmosphere:GetPropertyChangedSignal("Density"):Connect(r))
    end
    table.insert(connections, Lighting:GetPropertyChangedSignal("ClockTime"):Connect(r))
end

local function applyGenophageRemoval()
    safeCall(function()
        local cc = Lighting:FindFirstChild("GenophageColorCorrection")
        if not cc then return end
        if state.removeGenophage then
            cc.Enabled = false; cc.Brightness = 0
        else
            cc.Enabled = originalLighting.GenophageEnabled
            cc.Brightness = originalLighting.GenophageBrightness
        end
    end, "applyGenophageRemoval")
end

local function setupGenophageProtection()
    local function r() if state.removeGenophage then applyGenophageRemoval() end end
    local cc = Lighting:FindFirstChild("GenophageColorCorrection")
    if cc then
        table.insert(connections, cc:GetPropertyChangedSignal("Enabled"):Connect(r))
        table.insert(connections, cc:GetPropertyChangedSignal("Brightness"):Connect(r))
    else
        local scanCon
        scanCon = Lighting.ChildAdded:Connect(function(child)
            if child.Name == "GenophageColorCorrection" then
                scanCon:Disconnect()
                originalLighting.GenophageEnabled    = child.Enabled
                originalLighting.GenophageBrightness = child.Brightness
                table.insert(connections, child:GetPropertyChangedSignal("Enabled"):Connect(r))
                table.insert(connections, child:GetPropertyChangedSignal("Brightness"):Connect(r))
                r()
            end
        end)
        table.insert(connections, scanCon)
    end
end

--[[ AUTO PICKUP ]]
local function stopPickup()
    if pickupTask then pcall(task.cancel, pickupTask); pickupTask = nil end
end

local function setupAutoPickup()
    stopPickup()
    pickedUpPrompts = setmetatable({}, {__mode = "k"})
    if not state.autoPickup then return end

    local function trigger()
        local now = tick()
        if now - lastPickupTime < 0.1 then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local hrpPos = hrp.Position
        local bestPriority, bestDist = math.huge, math.huge
        local bestPrompt = nil

        for obj, info in pairs(espHandles) do
            local prio = PICKUP_PRIORITY[info.type]
            if not prio then continue end
            local stateKey = PICKUP_STATE_KEY[info.type]
            if not state[stateKey] then continue end
            if not (info.adornee and info.adornee.Parent) then continue end

            local prompt = info.prompt
            if not (prompt and prompt.Parent and prompt.Enabled and not pickedUpPrompts[prompt]) then continue end

            local dist = (info.adornee.Position - hrpPos).Magnitude
            if dist > 100 then continue end

            if prio < bestPriority or (prio == bestPriority and dist < bestDist) then
                bestPriority = prio
                bestDist     = dist
                bestPrompt   = prompt
            end
        end

        if bestPrompt then
            lastPickupTime = now
            pickedUpPrompts[bestPrompt] = true
            task.spawn(function()
                safeCall(function()
                    if bestPrompt and bestPrompt.Parent then
                        local dur = bestPrompt.HoldDuration
                        bestPrompt:InputHoldBegin()
                        task.wait(dur > 0 and dur or 0.1)
                        bestPrompt:InputHoldEnd()
                    end
                end, "autoPickup")
                pickedUpPrompts[bestPrompt] = nil
            end)
        end
    end

    pickupTask = task.spawn(function()
        while task.wait(0.05) do
            if not state.autoPickup then break end
            safeCall(trigger, "pickupLoop")
        end
        pickupTask = nil
    end)
end

