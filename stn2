        state.fullbrightEnhanced = v; applyFullbright(); applyEnhancedFullbright()
    end)
    makeToggle("Disable Bloom",     state.disableBloom, function(v) state.disableBloom    = v applyEnhancedFullbright() end)
    makeToggle("Disable Blur",      state.disableBlur,  function(v) state.disableBlur     = v applyEnhancedFullbright() end)
