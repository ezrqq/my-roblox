local function updateMinimap()
    if not state.minimapEnabled or not minimapFrame then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local hrpPos   = hrp.Position
    local camLook  = Workspace.CurrentCamera.CFrame.LookVector
    local camAngle = math.atan2(-camLook.X, -camLook.Z)
    local cosA, sinA = math.cos(-camAngle), math.sin(-camAngle)

    local half = MINIMAP_SIZE / 2
    local idx  = 0

    local function placeDot(worldPos, color, dotSize)
        if idx >= MINIMAP_POOL then return end
        local rel = worldPos - hrpPos
        if math.abs(rel.Y) > 60 then return end  -- skip different floors

        local rx =  rel.X * cosA - rel.Z * sinA
        local rz =  rel.X * sinA + rel.Z * cosA

        local px = half + rx / MINIMAP_STUDS
        local pz = half + rz / MINIMAP_STUDS

        -- Clamp to circle (hide if outside radius)
        local dx, dz = px - half, pz - half
        if dx*dx + dz*dz > half*half then return end

        idx = idx + 1
        local dot = minimapPool[idx]
        local sz  = dotSize or 5
        dot.Size             = UDim2.new(0, sz, 0, sz)
        dot.BackgroundColor3 = color
        dot.Position         = UDim2.new(0, px, 0, pz)
        dot.Visible          = true
    end

    for obj, info in pairs(espHandles) do
        if info.adornee and info.adornee.Parent then
            local color  = customColors[info.type] or Color3.new(1,1,1)
            local dotSize = (info.type == "Slasher") and 8
                         or (info.type == "Survivor" or info.type == "Friend") and 7
                         or 5
            if info.type == "Slasher" and info.outline and info.outline.Parent then
                color = info.outline.Color3   -- respects chainsaw color
            end
            placeDot(info.adornee.Position, color, dotSize)
        end
    end

    -- Hide unused dots
    for i = idx + 1, MINIMAP_POOL do
        minimapPool[i].Visible = false
    end
end

