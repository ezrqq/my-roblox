local dangerTweenIn  = nil
local dangerTweenOut = nil
local dangerActive   = false

local function setDangerActive(active)
    if active == dangerActive then return end
    dangerActive = active

    if dangerTweenIn  then dangerTweenIn:Cancel()  end
    if dangerTweenOut then dangerTweenOut:Cancel()  end

    local targetTrans = active and 0.55 or 1
    local info = TweenInfo.new(active and 0.3 or 0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)

    for _, edge in ipairs(dangerEdges) do
        TweenService:Create(edge, info, {BackgroundTransparency = targetTrans}):Play()
    end

    if active and state.alertSoundEnabled then
        local now = tick()
        if now - lastAlertTime > 5 then
            lastAlertTime = now
            pcall(function() alertSound:Play() end)
        end
    end
end

local function updateSlasherArrow(slasherWorldPos)
    if not arrowLabel or not overlayGui then return end
    if not state.slasherArrowEnabled then
        arrowLabel.Visible = false
        return
    end

    local cam        = Workspace.CurrentCamera
    local vpSize     = cam.ViewportSize
    local screenPos, onScreen = cam:WorldToViewportPoint(slasherWorldPos)

    if onScreen and screenPos.X > 40 and screenPos.X < vpSize.X - 40
    and screenPos.Y > 40 and screenPos.Y < vpSize.Y - 40 then
        arrowLabel.Visible = false
        return
    end

    arrowLabel.Visible = true

    local cx = vpSize.X / 2
    local cy = vpSize.Y / 2
    local dx = screenPos.X - cx
    local dy = screenPos.Y - cy

    local angle   = math.atan2(dy, dx)
    local padding = 55

    local halfW = cx - padding
    local halfH = cy - padding
    local absDx, absDy = math.abs(dx), math.abs(dy)

    local ex, ey
    if absDx == 0 and absDy == 0 then
        arrowLabel.Visible = false
        return
    end

    if absDx * halfH >= absDy * halfW then
        local sign = dx >= 0 and 1 or -1
        ex = sign * halfW
        ey = (absDx > 0) and (dy / absDx * halfW) or 0
    else
        local sign = dy >= 0 and 1 or -1
        ey = sign * halfH
        ex = (absDy > 0) and (dx / absDy * halfH) or 0
    end

    arrowLabel.Position = UDim2.new(0.5, ex, 0.5, ey)
    arrowLabel.Rotation = math.deg(angle)
end

