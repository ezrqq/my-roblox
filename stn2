--[[ MAIN HEARTBEAT LOOP ]]
-- Single Heartbeat connection with per-feature accumulators
do
    local accESP      = 0
    local accOverlay  = 0
    local accMinimap  = 0

    runningTasks.heartbeat = RunService.Heartbeat:Connect(function(dt)
        accESP     = accESP     + dt
        accOverlay = accOverlay + dt
        accMinimap = accMinimap + dt

        -- ESP + Stats (every 0.1s)
        if accESP >= CONFIG.Performance.ESPUpdateInterval then
            accESP = 0
            safeCall(function()
                slasherSortType    = "N/A"
                slasherChainsawCount = "N/A"
                local slasherFound = false

                local anyEnabled = state.showSlasher or state.showSurvivors or state.showFriends
                    or state.showEscapes or state.showBatterys or state.showBandages
                    or state.showCoins  or state.showFilms    or state.showMedkits or state.showChainsaws
                if not anyEnabled then return end

                local char = LocalPlayer.Character
                if not char then return end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local hrpPos = hrp.Position
                itemCounts = {coins=0, films=0, medkits=0, batterys=0, bandages=0}

                for obj, info in pairs(espHandles) do
                    local adornee = info.adornee
                    if not (adornee and adornee.Parent and info.gui and info.gui.Parent) then
                        removeESP(obj)
                        continue
                    end

                    local dist = (adornee.Position - hrpPos).Magnitude
                    local t    = info.type

                    if dist > CONFIG.Performance.MaxESPDistance and t ~= "Slasher" then
                        continue
                    end

                    -- LOD
                    if state.lodEnabled and t ~= "Slasher" then
                        local newLod = dist < 150 and LOD_FULL or dist < 350 and LOD_MEDIUM or LOD_LOW
                        if newLod ~= info.lodLevel then
                            info.lodLevel   = newLod
                            info.gui.Enabled = newLod ~= LOD_LOW
                            if info.outline then
                                info.outline.Adornee = (newLod == LOD_FULL) and info.outlineTarget or nil
                            end
                        end
                    end

                    if t == "Slasher" then
                        local color  = customColors.Slasher
                        local hasSaw = false
                        local stats  = info.stats

                        if stats and stats.Parent then
                            local sawVal = stats:FindFirstChild("Chainsaw")
                            if sawVal and sawVal:IsA("NumberValue") and sawVal.Value > 0 then
                                hasSaw = true
                                color  = CONFIG.DefaultColors.SlasherChainsaw
                            end
                            if not slasherFound then
                                slasherFound = true
                                local sType  = stats:FindFirstChild("SortType")
                                slasherSortType      = (sType and sType:IsA("StringValue")) and sType.Value or "Unknown"
                                slasherChainsawCount = hasSaw and tostring(sawVal.Value) or "N/A"
                            end
                        elseif not slasherFound then
                            slasherFound = true
                            slasherSortType = "Unknown"; slasherChainsawCount = "N/A"
                        end

                        if info.outline and info.outline.Parent then
                            info.outline.Color3 = color
                        end

                        local lbl = info.espLabel
                        if lbl and info.playerName then
                            local distTxt = dist <= 2000 and string.format(" (%.0fm)", dist) or ""
                            lbl.Text = info.playerName.." [Slasher]"..distTxt
                            lbl.TextColor3 = dist < 125 and COLOR_CLOSE or dist <= 215 and COLOR_MID or COLOR_FAR
                        end

                    elseif t == "Escape" then
                        local lbl = info.espLabel
                        if lbl then
                            local distTxt = dist <= 2000 and string.format(" (%.0fm)", dist) or ""
                            lbl.Text = "Escape"..distTxt
                        end
                    elseif t == "Coin"    then itemCounts.coins    = itemCounts.coins    + 1
                    elseif t == "Film"    then itemCounts.films    = itemCounts.films    + 1
                    elseif t == "Medkit"  then itemCounts.medkits  = itemCounts.medkits  + 1
                    elseif t == "Battery" then itemCounts.batterys = itemCounts.batterys + 1
                    elseif t == "Bandage" then itemCounts.bandages = itemCounts.bandages + 1
                    end
                end

                if statsUI and statsUI.label and statsUI.slasherLabel then
                    statsUI.label.Text = string.format(
                        "C: %d | F: %d | M: %d | B: %d | BD: %d",
                        itemCounts.coins, itemCounts.films, itemCounts.medkits,
                        itemCounts.batterys, itemCounts.bandages
                    )
                    statsUI.slasherLabel.Text = string.format(
                        "Slasher Type: %s | Ch: %s", slasherSortType, slasherChainsawCount
                    )
                end
            end, "espUpdateLoop")
        end

        -- Proximity alert + slasher arrow (every 0.05s)
        if accOverlay >= 0.05 then
            accOverlay = 0
            safeCall(function()
                if not (state.alertEnabled or state.slasherArrowEnabled) then
                    if dangerActive then setDangerActive(false) end
                    if arrowLabel then arrowLabel.Visible = false end
                    return
                end

                local char = LocalPlayer.Character
                if not char then
                    if dangerActive then setDangerActive(false) end
                    if arrowLabel then arrowLabel.Visible = false end
                    return
                end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local hrpPos       = hrp.Position
                local slasherClose = false
                local slasherWorldPos = nil

                for obj, info in pairs(espHandles) do
                    if info.type == "Slasher" and info.adornee and info.adornee.Parent then
                        local d = (info.adornee.Position - hrpPos).Magnitude
                        if d < 125 and math.abs(info.adornee.Position.Y - hrpPos.Y) < 25 then
                            slasherClose = true
                        end
                        slasherWorldPos = info.adornee.Position
                        break
                    end
                end

                if state.alertEnabled then setDangerActive(slasherClose) end

                if state.slasherArrowEnabled and slasherWorldPos then
                    updateSlasherArrow(slasherWorldPos)
                elseif arrowLabel then
                    arrowLabel.Visible = false
                end
            end, "overlayLoop")
        end

        -- Minimap (every 0.1s)
        if accMinimap >= 0.1 then
            accMinimap = 0
            if state.minimapEnabled then
                safeCall(updateMinimap, "minimapLoop")
            end
        end
    end)
end

