        makeColorRow(typeName)
    end

    -- Drag
    local dragging, dragStart, startPos = false, nil, nil
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    table.insert(connections, UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local d = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
    end))

    table.insert(connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end))

    table.insert(connections, UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        local ok, kc = pcall(function() return Enum.KeyCode[state.menuKeyName] end)
        if not ok then return end
        if input.KeyCode ~= kc then return end
        local sf = frame:FindFirstChild("ScrollContent")
        if sf and sf:IsA("ScrollingFrame") then
            if frame.Visible then
                menuScrollPosition = sf.CanvasPosition.Y
            else
                sf.CanvasPosition = Vector2.new(0, menuScrollPosition)
            end
        end
        frame.Visible = not frame.Visible
    end))
end

