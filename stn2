--[[ UTILITY ]]
local function safeCall(func, context)
    local ok, err = pcall(func)
    if not ok then
        warn(string.format("[STN] Error in %s: %s", context or "unknown", tostring(err)))
    end
    return ok
end

local function findInPath(root, path)
    if not path then return nil end
    local obj = root
    for _, name in ipairs(path) do
        if not obj then return nil end
        obj = obj:FindFirstChild(name)
    end
    return obj
end

local function findAdornee(obj)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart end
        local hrp = obj:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp end
    end
    for _, child in ipairs(obj:GetDescendants()) do
        if child:IsA("BasePart") then return child end
    end
    return nil
end

local function findStats(model)
    if not model then return nil end
    local stats = model:FindFirstChild("Stats")
    if stats then return stats end
    local kit = model:FindFirstChild("Kit")
    if kit then return kit:FindFirstChild("Stats") end
    return nil
end

--[[ ESP ]]
local function removeESP(obj)
    if not obj then return false end
    local info = espHandles[obj]
    if not info then return false end
    safeCall(function()
        if info.gui     and info.gui.Parent     then info.gui:Destroy()     end
        if info.outline and info.outline.Parent then info.outline:Destroy() end
    end, "removeESP")
    espHandles[obj] = nil
    return true
end

local function clearAllESP()
    local keys = {}
    for obj in pairs(espHandles) do keys[#keys + 1] = obj end
    for _, obj in ipairs(keys) do removeESP(obj) end
end

-- FIX: SelectionBox parented to obj (not Workspace) - auto-destroyed with obj,
--      eliminates all potential leaks when weak key is GC'd before connections fire.
-- FIX: espLabel and stats cached in handle - eliminates FindFirstChild calls in hot loop.
-- FIX: prompt cached in handle - eliminates FindFirstChildWhichIsA in auto-pickup loop.
local function createESP(obj, text, color, itemType, isPlayer, cachedPrompt)
    if not obj or espHandles[obj] then return end
    local adornee = findAdornee(obj)
    if not adornee then return end

    local ok = safeCall(function()
        local gui = Instance.new("BillboardGui")
        gui.Name           = "ESP_Label"
        gui.Adornee        = adornee
        gui.Size           = UDim2.new(0, 120, 0, 20)
        gui.AlwaysOnTop    = true
        gui.LightInfluence = 0
        gui.StudsOffset    = Vector3.new(0, isPlayer and 3.5 or 2.5, 0)
        gui.ResetOnSpawn   = false
        gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        gui.Parent         = obj

        local label = Instance.new("TextLabel")
        label.Name                 = "ESP_Text"
        label.Size                 = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text                 = text
        label.TextScaled           = true
        label.Font                 = Enum.Font.GothamBold
        label.TextColor3           = color
        label.TextStrokeTransparency = 0.5
        label.Parent               = gui

        local outline = Instance.new("SelectionBox")
        outline.Name               = "ESP_Outline"
        outline.Adornee            = obj:IsA("Model") and obj or adornee
        outline.Color3             = color
        outline.LineThickness      = CONFIG.OutlineThickness
        outline.SurfaceTransparency = CONFIG.OutlineSurfaceTrans
        outline.SurfaceColor3      = color
        outline.Parent             = obj  -- parented to obj so destroyed with it

        local playerName = nil
        if itemType == "Slasher" then
            playerName = text:match("^(.-)%s*%[Slasher%]")
        elseif itemType == "Survivor" then
            playerName = text:match("^(.-)%s*%[Survivor%]")
        elseif itemType == "Friend" then
            playerName = text:match("^Friend%s+(.*)")
        end

        espHandles[obj] = {
            gui        = gui,
            outline    = outline,
            espLabel   = label,        -- cached, no FindFirstChild in loop
            type       = itemType or "Unknown",
            adornee    = adornee,
            playerName = playerName,
            stats      = findStats(obj), -- cached for slasher update loop
            prompt     = cachedPrompt,  -- cached for auto-pickup loop
        }
    end, "createESP")

    return ok
end

--[[ PROMPT MONITORING ]]
local function isPromptEnabled(prompt)
    return prompt ~= nil and prompt.Enabled
end

local function monitorPrompt(obj, prompt)
    if not obj or not prompt then return end
    local old = itemPromptConnections[obj]
    if old then old:Disconnect() end
    local con = prompt:GetPropertyChangedSignal("Enabled"):Connect(function()
        if not isPromptEnabled(prompt) then removeESP(obj) end
    end)
    itemPromptConnections[obj] = con
    if not isPromptEnabled(prompt) then removeESP(obj) end
end

local function stopMonitoringPrompt(obj)
    local con = itemPromptConnections[obj]
    if con then
        con:Disconnect()
        itemPromptConnections[obj] = nil
    end
end

--[[ PLAYER TRACKING ]]
local function isFriendOfLocal(plr)
    return plr ~= nil and friendsCache[plr.UserId] == true
end

local function getPlayerTeamColor(player)
    if not player or not player.Character then return nil end
    local kit = player.Character:FindFirstChild("Kit")
    if not kit then return nil end
    local stats = kit:FindFirstChild("Stats")
    if not stats then return nil end
    local teamColor = stats:FindFirstChild("TeamColor")
    return teamColor and teamColor.Value
end

-- FIX: Added retry mechanism for when Kit/Stats haven't replicated yet.
local function updateCharacterESP(model)
    safeCall(function()
        if not model or model == LocalPlayer.Character then
            removeESP(model)
            return
        end
        local player = Players:GetPlayerFromCharacter(model)
        if not player then removeESP(model) return end

        local isFriend = isFriendOfLocal(player)
        local stats    = findStats(model)

        if stats then
            local typ = stats:FindFirstChild("Type")
            if typ and typ:IsA("StringValue") then
                if typ.Value:lower() == "slasher" then
                    if state.showSlasher then
                        createESP(model, player.Name .. " [Slasher]", CONFIG.PlayerColors.Slasher, "Slasher", true)
                    else
                        removeESP(model)
                    end
                    return
                end
            end
        end

        local teamColor = getPlayerTeamColor(player)
        if not teamColor then
            removeESP(model)
            return
        end

        local r, g, b   = teamColor.R, teamColor.G, teamColor.B
        local isSurvivor = r < 0.1 and g > 0.9 and b < 0.1

        if isFriend and state.showFriends then
            createESP(model, "Friend " .. player.Name, COLOR_FRIEND, "Friend", true)
        elseif isSurvivor and state.showSurvivors and not isFriend then
            createESP(model, player.Name .. " [Survivor]", CONFIG.PlayerColors.Survivor, "Survivor", true)
        else
            removeESP(model)
        end
    end, "updateCharacterESP")
end

--[[ FOLDER MONITORING ]]
local function disconnectMonitors()
    for _, con in pairs(monitoredFolders) do
        if con and con.Disconnect then con:Disconnect() end
    end
    monitoredFolders = {}
    for _, con in pairs(itemPromptConnections) do
        if con and con.Disconnect then con:Disconnect() end
    end
    itemPromptConnections = setmetatable({}, {__mode = "k"})
end

local function setupMonitor(folder, itemType, color)
    if not folder then return end

    local function handleChild(child)
        if not child then return end
        local prompt = child:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then monitorPrompt(child, prompt) end
        -- Pass cached prompt to createESP so auto-pickup doesn't search again
        createESP(child, itemType, color, itemType, false, prompt)
        local con = child.AncestryChanged:Connect(function(_, newParent)
            if not newParent then
                removeESP(child)
                stopMonitoringPrompt(child)
            end
        end)
        table.insert(connections, con)
    end

    for _, child in ipairs(folder:GetChildren()) do handleChild(child) end

    local addedCon   = folder.ChildAdded:Connect(handleChild)
    local removedCon = folder.ChildRemoved:Connect(function(child)
        removeESP(child)
        stopMonitoringPrompt(child)
    end)

    table.insert(monitoredFolders, addedCon)
    table.insert(monitoredFolders, removedCon)
    table.insert(connections, addedCon)
    table.insert(connections, removedCon)
end

local function detectAndSetupMonitors()
    disconnectMonitors()
    for _, itemData in ipairs(ITEM_SETTINGS) do
        if state[itemData.stateKey] then
            local folder = findInPath(Workspace, itemData.folderPath)
            if folder then
                setupMonitor(folder, itemData.type, itemData.color)
            end
        end
    end
end

local function updateAllESP()
    if isUpdatingESP then return end
    isUpdatingESP = true
    safeCall(function()
        clearAllESP()
        detectAndSetupMonitors()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                updateCharacterESP(player.Character)
            end
        end
    end, "updateAllESP")
    isUpdatingESP = false
end

--[[ ROUND DETECTION ]]
local function watchForNewRounds()
    local function checkForTempMap()
        if Workspace:FindFirstChild("TempMap") then
            task.delay(0.8, updateAllESP)
        end
    end
    table.insert(connections, Workspace.ChildAdded:Connect(function(child)
        if child.Name == "TempMap" then checkForTempMap() end
    end))
    checkForTempMap()
end

--[[ FRIENDS CACHE ]]
local function refreshFriends()
    friendsCache = setmetatable({}, {__mode = "kv"})
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            safeCall(function()
                if LocalPlayer:IsFriendsWith(player.UserId) then
                    friendsCache[player.UserId] = true
                end
            end, "refreshFriends")
        end
    end
end

--[[ LIGHTING ]]
local function applyFullbright()
    safeCall(function()
        if state.fullbright then
            Lighting.Brightness              = 2
            Lighting.FogEnd                  = 1e9
            Lighting.GlobalShadows           = false
            Lighting.Technology              = Enum.Technology.ShadowMap
            Lighting.EnvironmentDiffuseScale = 1
            Lighting.EnvironmentSpecularScale= 1
        else
            Lighting.Brightness              = originalLighting.Brightness
            Lighting.FogEnd                  = originalLighting.FogEnd
            Lighting.GlobalShadows           = originalLighting.GlobalShadows
            Lighting.Technology              = originalLighting.Technology
            Lighting.EnvironmentDiffuseScale = originalLighting.EnvDiffuse
            Lighting.EnvironmentSpecularScale= originalLighting.EnvSpecular
        end
    end, "applyFullbright")
end

local function setupFullbrightProtection()
    local function reapply()
        if state.fullbright then applyFullbright() end
    end
    table.insert(connections, Lighting:GetPropertyChangedSignal("Brightness"):Connect(reapply))
    table.insert(connections, Lighting:GetPropertyChangedSignal("FogEnd"):Connect(reapply))
    table.insert(connections, Lighting:GetPropertyChangedSignal("GlobalShadows"):Connect(reapply))
    table.insert(connections, Lighting:GetPropertyChangedSignal("Technology"):Connect(reapply))
end

local function applyEnhancedFullbright()
    safeCall(function()
        if Lighting.Atmosphere then
            Lighting.Atmosphere.Density = state.fullbrightEnhanced and 0 or originalLighting.AtmosphereDensity
        end
        if state.fullbrightEnhanced then
            Lighting.ClockTime     = 14
            Lighting.Ambient       = Color3.fromRGB(200, 200, 200)
            Lighting.OutdoorAmbient= Color3.fromRGB(200, 200, 200)
        else
            Lighting.ClockTime     = originalLighting.ClockTime
            Lighting.Ambient       = originalLighting.Ambient
            Lighting.OutdoorAmbient= originalLighting.OutdoorAmbient
        end
        local bloom = Lighting:FindFirstChild("DefaultBloom")
        if bloom then bloom.Enabled = not state.disableBloom end
        local blur  = Lighting:FindFirstChild("DefaultBlur")
        if blur  then blur.Enabled  = not state.disableBlur  end
    end, "applyEnhancedFullbright")
end

local function setupEnhancedFullbrightProtection()
    local function reapply()
        if state.fullbrightEnhanced then applyEnhancedFullbright() end
    end
    if Lighting.Atmosphere then
        table.insert(connections, Lighting.Atmosphere:GetPropertyChangedSignal("Density"):Connect(reapply))
    end
    table.insert(connections, Lighting:GetPropertyChangedSignal("ClockTime"):Connect(reapply))
end

local function applyGenophageRemoval()
    safeCall(function()
        local cc = Lighting:FindFirstChild("GenophageColorCorrection")
        if not cc then return end
        if state.removeGenophage then
            cc.Enabled    = false
            cc.Brightness = 0
        else
            cc.Enabled    = originalLighting.GenophageEnabled
            cc.Brightness = originalLighting.GenophageBrightness
        end
    end, "applyGenophageRemoval")
end

-- FIX: ChildAdded connection disconnects itself once the target is found (no leak).
local function setupGenophageProtection()
    local function reapply()
        if state.removeGenophage then applyGenophageRemoval() end
    end
    local cc = Lighting:FindFirstChild("GenophageColorCorrection")
    if cc then
        table.insert(connections, cc:GetPropertyChangedSignal("Enabled"):Connect(reapply))
        table.insert(connections, cc:GetPropertyChangedSignal("Brightness"):Connect(reapply))
    else
        local scanCon
        scanCon = Lighting.ChildAdded:Connect(function(child)
            if child.Name == "GenophageColorCorrection" then
                scanCon:Disconnect()  -- stop scanning, target found
                originalLighting.GenophageEnabled    = child.Enabled
                originalLighting.GenophageBrightness = child.Brightness
                table.insert(connections, child:GetPropertyChangedSignal("Enabled"):Connect(reapply))
                table.insert(connections, child:GetPropertyChangedSignal("Brightness"):Connect(reapply))
                reapply()
            end
        end)
        table.insert(connections, scanCon)
    end
end

--[[ AUTO PICKUP ]]
-- FIX: pickupTask tracked as a standalone thread, NOT inserted into connections,
--      preventing stale cancelled-task entries accumulating on every toggle.
local function stopPickup()
    if pickupTask then
        task.cancel(pickupTask)
        pickupTask = nil
    end
end

local function setupAutoPickup()
    stopPickup()
    pickedUpPrompts = setmetatable({}, {__mode = "k"})
    if not state.autoPickup then return end

    local function triggerNearbyPrompts()
        local now = tick()
        if now - lastPickupTime < 0.1 then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local hrpPos = hrp.Position
        local best, bestDist = nil, math.huge

        for obj, info in pairs(espHandles) do
            if (info.type == "Film" and state.showFilms) or (info.type == "Coin" and state.showCoins) then
                if info.adornee and info.adornee.Parent then
                    -- FIX: use cached prompt from espHandles, no traversal needed
                    local prompt = info.prompt
                    if prompt and prompt.Parent and prompt.Enabled and not pickedUpPrompts[prompt] then
                        local dist = (info.adornee.Position - hrpPos).Magnitude
                        if dist < 100 and dist < bestDist then
                            bestDist = dist
                            best     = prompt
                        end
                    end
                end
            end
        end

        if best then
            lastPickupTime = now
            pickedUpPrompts[best] = true
            task.spawn(function()
                safeCall(function()
                    if best and best.Parent then
                        local dur = best.HoldDuration
                        best:InputHoldBegin()
                        task.wait(dur > 0 and dur or 0.1)
                        best:InputHoldEnd()
                    end
                end, "autoPickup")
                pickedUpPrompts[best] = nil
            end)
        end
    end

    pickupTask = task.spawn(function()
        while task.wait(0.05) do
            if not state.autoPickup then break end
            safeCall(triggerNearbyPrompts, "pickupLoop")
        end
        pickupTask = nil
    end)
end

--[[ UI HELPERS ]]
local TWEEN_FAST = TweenInfo.new(0.2, Enum.EasingStyle.Quad,  Enum.EasingDirection.Out)
local TWEEN_SLOW = TweenInfo.new(ANIM_DURATION, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

local function createRoundedFrame(size, position, parent, withGlow, bgTrans, bgColor, cornerRadius, zIndex)
    local frame = Instance.new("Frame")
    frame.Size                 = size or UDim2.new(1, 0, 0, 40)
    frame.Position             = position or UDim2.new(0, 0, 0, 0)
    frame.BackgroundColor3     = bgColor or Color3.fromRGB(25, 25, 25)
    frame.BackgroundTransparency = bgTrans or 0.5
    frame.BorderSizePixel      = 0
    if zIndex then frame.ZIndex = zIndex end
    frame.Parent               = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = cornerRadius or CONFIG.Visual.CornerRadius
    corner.Parent       = frame

    local glowCfg = type(withGlow) == "table" and withGlow or nil
    if glowCfg and state.enableGlow then
        local stroke = Instance.new("UIStroke")
        stroke.Color           = CONFIG.Visual.GlowColor
        stroke.Transparency    = CONFIG.Visual.GlowTransparency
        stroke.Thickness       = CONFIG.Visual.GlowThickness * (glowCfg.thicknessMultiplier or 1)
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.LineJoinMode    = Enum.LineJoinMode.Round
        stroke.Parent          = frame
        frame:SetAttribute("HasGlow", true)
    end

    return frame
end

local function updateGlowVisibility()
    for _, frame in ipairs(mainGlowFrames) do
        if frame and frame.Parent then
            local stroke = frame:FindFirstChildOfClass("UIStroke")
            if stroke then stroke.Enabled = state.enableGlow end
        end
    end
end

local function setupDynamicGlow()
    if not state.enableGlow then return nil end

    local cycle    = 2.5
    local minColor = Color3.fromRGB(150, 150, 150)
    local maxColor = CONFIG.Visual.GlowColor

    return task.spawn(function()
        while task.wait(1/60) do
            if not state.enableGlow then
                task.wait(1)
                continue
            end
            local t        = (tick() % cycle) / cycle
            local progress = 0.5 * math.sin(t * math.pi * 2) + 0.5
            local newColor = minColor:Lerp(maxColor, progress)

            for i = #mainGlowFrames, 1, -1 do
                local frame = mainGlowFrames[i]
                if frame and frame.Parent then
                    local stroke = frame:FindFirstChildOfClass("UIStroke")
                    if stroke then stroke.Color = newColor end
                else
                    table.remove(mainGlowFrames, i)
                end
            end
        end
    end)
end

