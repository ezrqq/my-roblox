--[[ CLEANUP ]]
local cleanedUp = false
local function cleanup()
    if cleanedUp then return end
    cleanedUp = true

    -- Cancel background tasks
    for _, thread in pairs(runningTasks) do
        if type(thread) == "thread" then
            pcall(task.cancel, thread)
        end
    end
    runningTasks = {}
    stopPickup()

    -- Disconnect all signals
    for _, con in ipairs(connections) do
        if con and type(con.Disconnect) == "function" then
            pcall(con.Disconnect, con)
        end
    end
    connections = {}

    disconnectMonitors()

    -- Restore lighting
    safeCall(function()
        Lighting.Brightness              = originalLighting.Brightness
        Lighting.FogEnd                  = originalLighting.FogEnd
        Lighting.GlobalShadows           = originalLighting.GlobalShadows
        Lighting.Technology              = originalLighting.Technology
        Lighting.EnvironmentDiffuseScale = originalLighting.EnvDiffuse
        Lighting.EnvironmentSpecularScale= originalLighting.EnvSpecular
        Lighting.ClockTime               = originalLighting.ClockTime
        Lighting.Ambient                 = originalLighting.Ambient
        Lighting.OutdoorAmbient          = originalLighting.OutdoorAmbient
        if Lighting.Atmosphere then
            Lighting.Atmosphere.Density = originalLighting.AtmosphereDensity
        end
        local bloom = Lighting:FindFirstChild("DefaultBloom")
        if bloom then bloom.Enabled = originalLighting.BloomEnabled end
        local blur  = Lighting:FindFirstChild("DefaultBlur")
        if blur  then blur.Enabled  = originalLighting.BlurEnabled  end
        local cc    = Lighting:FindFirstChild("GenophageColorCorrection")
        if cc and originalLighting.GenophageEnabled ~= nil then
            cc.Enabled    = originalLighting.GenophageEnabled
            cc.Brightness = originalLighting.GenophageBrightness
        end
    end, "cleanup:lighting")

    clearAllESP()

    if statsUI then
        pcall(function() statsUI.gui:Destroy() end)
        statsUI = nil
    end

    local ui = PlayerGui:FindFirstChild("ESP_UI")
    if ui then ui:Destroy() end

    print("[STN] Cleanup completed")
end

